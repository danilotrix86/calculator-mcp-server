# Supabase Configuration
SUPABASE_URL=""
SUPABASE_KEY=""

# Admin Authentication
ADMIN_USERNAME=""
ADMIN_PASSWORD=""

# OpenAI Configuration
OPENAI_API_KEY=""
OPENAI_MODEL="" # Optional, defaults to whatever is configured in code

# Server Configuration
# Required for CORS configuration if running behind a specific domain
CLOUD_RUN_URL=""
PORT=8080

# Rate Limiting (format: "N/period" where period is second, minute, hour, day)
RATE_LIMIT_SOLVE="15/minute"
RATE_LIMIT_MATRIX="30/minute"
RATE_LIMIT_BLOG="60/minute"
RATE_LIMIT_ADMIN="20/minute"
RATE_LIMIT_HEALTH="15/minute"
RATE_LIMIT_DEFAULT="120/minute"

# Max image upload size in bytes (default: 10 MB)
IMAGE_MAX_SIZE_BYTES=10485760